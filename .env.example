# Copy this to .env and fill in your values
# Get these from: developer.amazon.com -> Your Skill -> Build -> Permissions

LWA_CLIENT_ID=
LWA_CLIENT_SECRET=

# Target user ID (obtained from Lambda logs after invoking the skill)
ALEXA_USER_ID=

# Optional: na (default), eu, fe
ALEXA_REGION=na

# Optional: development (default) or live
SKILL_STAGE=development
